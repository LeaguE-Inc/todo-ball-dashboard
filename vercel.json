{
  "version": 2,
  "regions": ["sfo1"],
  "env": {},
  "public": true,
  "github": {
    "enabled": true,
    "autoAlias": true,
    "silent": false,
    "autoJobCancelPendingOnPush": true,
    "autoExposeSystemEnvs": false,
    "protected": [],
    "skipDeploymentDialogue": false
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, must-revalidate"
        }
      ]
    }
  ]
}
